# =========================================================================
# GPLINKS AFFILIATE DEAL FORWARDER - ENVIRONMENTAL CONFIGURATION TEMPLATE
# =========================================================================

# [TELEGRAM CONFIGURATION]
# Your Telegram Bot Token from @BotFather (e.g., 1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ)
TELEGRAM_BOT_TOKEN=

# Source Telegram Channel Username or numeric ID (where you share links/images)
# (e.g., -1001234567890 or @my_source_channel)
TELEGRAM_SOURCE_CHANNEL=

# Destination Telegram Channel Username or numeric ID (where shortened deals are posted)
# (e.g., -1009876543210 or @my_public_deals)
TELEGRAM_DEST_CHANNEL=

# [DISCORD INTEGRATION]
# Mode: 'webhook' (single server hook) or 'bot' (multi-channel bot client API)
DISCORD_MODE=webhook

# Your Discord channel webhook URL (required if mode is webhook)
DISCORD_WEBHOOK_URL=

# Your Discord Bot Token (required if mode is bot)
DISCORD_BOT_TOKEN=

# Comma-separated list of target Discord Channel IDs (required if mode is bot)
DISCORD_CHANNEL_IDS=

# [GPLINKS API INTEGRATION]
# Your Developers API Token from gplinks.com/member/tools/api
GPLINKS_API_TOKEN=a0e6a6c4443a5e524a02ea016a3dd79139a2e2a7

# [DASHBOARD SECURITY]
# Access password for the glassmorphic control dashboard (e.g., admin123)
DASHBOARD_PASSWORD=admin123
